# ─── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Optional ─────────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=

# ─── Development Auth Bypass (REMOVE OR DISABLE BEFORE GO LIVE) ───────────────
# Set VITE_DISABLE_AUTH=true to skip frontend auth guards in local development.
# Requires VITE_DEV_USER_ID and VITE_DEV_ORG_ID — both must be real IDs from your
# Supabase database. Supabase RLS is NOT bypassed; your dev session must exist.
# See README.md > Development Auth Bypass for full setup instructions.
VITE_DISABLE_AUTH=false
VITE_DEV_USER_ID=
VITE_DEV_ORG_ID=
VITE_DEV_USER_EMAIL=
